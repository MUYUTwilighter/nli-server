NLI_ENV=development
NLI_BIND_ADDR=127.0.0.1:8080

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/nli_server
REDIS_URL=redis://127.0.0.1:6379/0

INSTANCE_TOKEN_TTL_SECONDS=1800
PRESENCE_TTL_SECONDS=90

TURN_URLS=stun:127.0.0.1:3478,turn:127.0.0.1:3478?transport=udp,turn:127.0.0.1:3478?transport=tcp
TURN_SHARED_SECRET=change-me-local-turn-secret
TURN_CREDENTIAL_TTL_SECONDS=600

MINECRAFT_PROFILE_URL=https://api.minecraftservices.com/minecraft/profile
RUST_LOG=nli_server=debug,tower_http=debug
