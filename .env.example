NLI_ENV=development
NLI_BIND_ADDR=127.0.0.1:8080
# NLI_CORS_ALLOW_ORIGIN=https://example.com

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/nli_server
REDIS_URL=redis://127.0.0.1:6379/0

INSTANCE_TOKEN_TTL_SECONDS=1800
PRESENCE_TTL_SECONDS=90
SIGNALING_SESSION_TTL_SECONDS=300
PROFILE_CACHE_TTL_SECONDS=21600
NLI_TRUST_PROXY_HEADERS=false
# Optional. When set, GET /metrics requires Authorization: Bearer <token>.
# NLI_METRICS_TOKEN=replace-with-random-monitoring-token

# Development-only loopback example. Production must use a client-reachable coturn host.
TURN_URLS=stun:127.0.0.1:3478,turn:127.0.0.1:3478?transport=udp,turn:127.0.0.1:3478?transport=tcp
TURN_SHARED_SECRET=change-me-local-turn-secret
TURN_CREDENTIAL_TTL_SECONDS=600

MINECRAFT_PROFILE_URL=https://api.minecraftservices.com/minecraft/profile
MINECRAFT_PROFILE_BY_NAME_URL=https://api.mojang.com/users/profiles/minecraft/
MINECRAFT_PROFILE_BY_ID_URL=https://sessionserver.mojang.com/session/minecraft/profile/
MINECRAFT_FRIENDS_URL=https://api.minecraftservices.com/friends
RUST_LOG=nli_server=debug,tower_http=debug
